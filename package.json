{
  "name": "app-ai-translator",
  "version": "2.0.0",
  "private": true,
  "description": "Juke AI Translator",
  "homepage": "https://github.com/enonic/app-ai-translator",
  "bugs": {
    "url": "https://github.com/enonic/app-ai-translator/issues"
  },
  "license": "Enonic License 2.0",
  "author": "Enonic",
  "contributors": [
    "Mikita Taukachou <edloidas@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enonic/app-ai-translator"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:dev",
    "build:prod": "pnpm run /^build:prod:.*/",
    "build:prod:client": "NODE_ENV=production vp build --mode production",
    "build:prod:server": "NODE_ENV=production node esbuild.server.js",
    "build:dev": "pnpm run /^build:dev:.*/",
    "build:dev:client": "NODE_ENV=development vp build --mode development",
    "build:dev:server": "NODE_ENV=development node esbuild.server.js",
    "check": "vp lint && pnpm check:types && pnpm test",
    "check:types": "tsgo --noEmit -p src/main/resources/tsconfig.json && tsgo --noEmit",
    "test": "vp test --run",
    "fix": "vp fmt && vp lint --fix",
    "prepare": "vp config",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@nanostores/react": "~1.1.0",
    "focus-trap-react": "~12.0.3",
    "i18next": "~26.3.6",
    "i18next-http-backend": "~4.0.0",
    "lodash.clonedeep": "~4.5.0",
    "lucide-react": "~1.25.0",
    "nanostores": "~1.4.0",
    "preact": "~10.29.7",
    "react-i18next": "~17.0.10",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@enonic-types/core": "^8",
    "@enonic-types/global": "^8",
    "@enonic-types/lib-auth": "^8",
    "@enonic-types/lib-content": "^8",
    "@enonic-types/lib-context": "^8",
    "@enonic-types/lib-schema": "^8",
    "@enonic-types/lib-task": "^8",
    "@enonic-types/lib-websocket": "^8",
    "@enonic/ui": "~1.0.5",
    "@google/genai": "~2.10.0",
    "@preact/preset-vite": "~2.10.6",
    "@storybook/addon-docs": "~10.4.6",
    "@storybook/addon-themes": "~10.4.6",
    "@storybook/preact-vite": "~10.4.6",
    "@swc/core": "^1.15.43",
    "@tailwindcss/vite": "~4.3.2",
    "@testing-library/jest-dom": "~6.9.1",
    "@types/lodash.clonedeep": "~4.5.9",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "esbuild": "~0.28.1",
    "jsdom": "~29.1.1",
    "storybook": "~10.4.6",
    "tailwindcss": "~4.3.3",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">= 24.16.0",
    "pnpm": ">= 11.4.0"
  },
  "packageManager": "pnpm@11.4.0"
}
