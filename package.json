{
    "name": "app-ai-translator",
    "version": "1.0.0",
    "description": "Juke AI Translator",
    "author": "Enonic",
    "license": "Apache-2.0",
    "private": true,
    "type": "module",
    "bugs": {
        "url": "https://github.com/enonic/app-ai-translator/issues"
    },
    "contributors": [
        "Mikita Taukachou <edloidas@gmail.com>"
    ],
    "homepage": "https://github.com/enonic/app-ai-translator",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enonic/app-ai-translator"
    },
    "packageManager": "pnpm@11.0.9",
    "engines": {
        "node": ">=24.15.0",
        "pnpm": ">=11.0.9"
    },
    "scripts": {
        "build": "pnpm build:dev",
        "build:prod": "pnpm run /^build:prod:.*/",
        "build:prod:client": "cross-env NODE_ENV=production vp build --mode production",
        "build:prod:server": "cross-env NODE_ENV=production node esbuild.server.js",
        "build:dev": "pnpm run /^build:dev:.*/",
        "build:dev:client": "cross-env NODE_ENV=development vp build --mode development",
        "build:dev:server": "cross-env NODE_ENV=development node esbuild.server.js",
        "check": "vp lint && pnpm check:types && pnpm test",
        "check:types": "tsgo --noEmit -p src/main/resources/tsconfig.json && tsgo --noEmit",
        "test": "vp test --run",
        "fix": "vp lint --fix",
        "prepare": "vp config"
    },
    "dependencies": {
        "@nanostores/react": "~1.1.0",
        "clsx": "~2.1.1",
        "focus-trap-react": "~12.0.1",
        "i18next": "~26.0.10",
        "i18next-http-backend": "~4.0.0",
        "lodash.clonedeep": "~4.5.0",
        "lodash.debounce": "~4.0.8",
        "lodash.isequal": "~4.5.0",
        "lodash.merge": "~4.6.2",
        "nanostores": "~1.3.0",
        "preact": "~10.29.1",
        "react-i18next": "~17.0.7",
        "tailwind-merge": "~3.5.0",
        "tailwindcss-scoped-preflight": "~4.0.6"
    },
    "devDependencies": {
        "@enonic-types/core": "8.0.0-B4",
        "@enonic-types/global": "8.0.0-B4",
        "@enonic-types/lib-auth": "8.0.0-B4",
        "@enonic-types/lib-content": "8.0.0-B4",
        "@enonic-types/lib-context": "8.0.0-B4",
        "@enonic-types/lib-schema": "8.0.0-B4",
        "@enonic-types/lib-task": "8.0.0-B4",
        "@enonic-types/lib-websocket": "8.0.0-B4",
        "@google/genai": "~2.0.1",
        "@preact/preset-vite": "~2.10.5",
        "@tailwindcss/vite": "~4.3.0",
        "@testing-library/jest-dom": "~6.9.1",
        "@types/lodash.clonedeep": "~4.5.9",
        "@types/lodash.debounce": "~4.0.9",
        "@types/lodash.isequal": "~4.5.8",
        "@types/lodash.merge": "~4.6.9",
        "@types/react": "~19.2.14",
        "@types/react-dom": "~19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260510.1",
        "cross-env": "~10.1.0",
        "esbuild": "~0.28.0",
        "jsdom": "~29.1.1",
        "tailwindcss": "~4.3.0",
        "typescript": "^6.0.3",
        "vite": "catalog:",
        "vite-plus": "catalog:",
        "vitest": "catalog:"
    }
}
