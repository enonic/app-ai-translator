{
    "oxc.path.oxlint": "./node_modules/vite-plus/bin/oxlint",
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "explicit"
    },
    "editor.tabSize": 4,
    "js/ts.experimental.useTsgo": true,
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "cSpell.words": ["clsx", "Dispatchable", "Enonic", "nanostores", "Oxlint", "preact", "tailwindcss", "translator", "tsgo"]
}
